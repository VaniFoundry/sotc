{
  "id": "sotc",
  "title": "Stars of the City",
  "description": "A system for playing Stars of the City, a Project Moon inspired TTRPG by Jakkafang and community.",
  "url": "https://github.com/VaniFoundry/sotc",
  "manifest": "https://raw.githubusercontent.com/VaniFoundry/sotc/master/system.json",
  "download": "https://github.com/VaniFoundry/sotc/releases/download/v1.0.2/sotc.zip",
  "authors": [
    {
      "name": "Tsubasa",
      "discord": "tsubasa______",
      "flags": {}
    }
  ],
  "version": "1.0.2",
  "compatibility": {
    "minimum": 11,
    "verified": "11.315"
  },
  "esmodules": [
    "module/sotc.js",
    "module/custom/group-initiative-sound.js"
  ],
  "styles": [
    "styles/sotc.css"
  ],
  "socket": true,
  "packs": [
    {
      "name": "default-statuses",
      "label": "Default Statuses",
      "system": "sotc",
      "path": "packs/default-statuses",
      "type": "Item",
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      },
      "flags": {}
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    }
  ],
  "gridDistance": 5,
  "gridUnits": "ft",
  "trackableAttributes": {
    "character": {
      "bar": [
        "system.health.value",
        "system.stagger.value",
        "system.light.value"
      ]
    }
  },
  "background": "systems/sotc/assets/home_page.png"
}
